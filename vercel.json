{
  "version": 2,
  "builds": [
    {
      "src": "dist/my-ssr/browser/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/my-ssr/browser/$1"
    },
    {
      "src": "/",
      "dest": "dist/my-ssr/browser/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
